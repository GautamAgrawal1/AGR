<%- include('partials/header') %>
<div style="padding:100px 24px 80px;max-width:1000px;margin:0 auto;background:var(--cream);min-height:100vh;">

  <% if(locals.booked) { %>
    <div style="background:#f0fdf4;border:1px solid #86efac;color:#166534;padding:14px 18px;border-radius:10px;margin-bottom:24px;font-size:14px;">🎉 Room book ho gayi! Payment karke booking confirm karein.</div>
  <% } %>

  <p style="font-family:'DM Mono',monospace;font-size:11px;letter-spacing:4px;color:var(--terracotta);text-transform:uppercase;margin-bottom:10px;">My Account</p>
  <h1 style="font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:600;margin-bottom:6px;color:var(--text);">Welcome, <%= user.name %></h1>
  <p style="color:var(--text-light);margin-bottom:48px;font-size:14px;"><%= user.email %> · <span style="color:var(--terracotta);font-weight:600;"><%= user.role %></span></p>

  <h2 style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:600;margin-bottom:24px;color:var(--text);">My Bookings</h2>

  <% if (bookings.length === 0) { %>
    <div style="text-align:center;padding:60px;background:var(--white);border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow-sm);">
      <p style="font-size:48px;margin-bottom:16px;">🏨</p>
      <h3 style="font-family:'Cormorant Garamond',serif;font-size:24px;margin-bottom:8px;color:var(--text);">Koi booking nahi</h3>
      <p style="color:var(--text-light);margin-bottom:24px;">Abhi tak koi room book nahi kiya.</p>
      <a href="/rooms" style="background:var(--terracotta);color:white;padding:12px 28px;border-radius:8px;font-size:14px;font-weight:500;">Browse Rooms</a>
    </div>
  <% } else { %>
    <div style="display:flex;flex-direction:column;gap:16px;">
      <% bookings.forEach(booking => { %>
        <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:24px;box-shadow:var(--shadow-sm);">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px;">

            <!-- Room Info -->
            <div style="display:flex;gap:16px;align-items:center;">
              <div style="width:60px;height:60px;background:var(--cream2);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:28px;border:1px solid var(--border);overflow:hidden;flex-shrink:0;">
                <% if(booking.room.coverImage){ %>
                  <img src="<%= booking.room.coverImage %>" style="width:100%;height:100%;object-fit:cover;">
                <% } else { %>
                  <%= booking.room.type==='Suite'?'👑':booking.room.type==='Deluxe AC'?'❄️':'🏠' %>
                <% } %>
              </div>
              <div>
                <h3 style="font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;color:var(--text);margin-bottom:3px;"><%= booking.room.name %></h3>
                <p style="color:var(--text-light);font-size:13px;">Room <%= booking.room.roomNumber %></p>
                <p style="color:var(--text-light);font-size:12px;margin-top:3px;">
                  <%= new Date(booking.checkIn).toDateString() %> → <%= new Date(booking.checkOut).toDateString() %>
                </p>
              </div>
            </div>

            <!-- Price + Status + Payment -->
            <div style="text-align:right;">
              <p style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;color:var(--terracotta);margin-bottom:6px;">₹<%= booking.totalAmount %></p>

              <% const statusColors = {
                Confirmed:  'background:#f0fdf4;color:#166534;border:1px solid #86efac;',
                Pending:    'background:#fff7ed;color:#9a3412;border:1px solid #fed7aa;',
                CheckedIn:  'background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;',
                CheckedOut: 'background:#f9fafb;color:#6b7280;border:1px solid #e5e7eb;',
                Cancelled:  'background:#fef2f2;color:#991b1b;border:1px solid #fca5a5;',
              } %>
              <span style="font-size:11px;padding:4px 12px;border-radius:99px;<%= statusColors[booking.status] || statusColors.Pending %>font-weight:600;">
                <%= booking.status %>
              </span>

              <!-- Payment Button — sirf Pending bookings pe -->
              <% if(booking.status === 'Pending' && booking.payment && booking.payment.status !== 'Paid') { %>
                <div style="margin-top:10px;">
                  <button onclick="payNow('<%= booking._id %>','<%= booking.totalAmount %>')"
                    style="background:var(--gold);color:white;border:none;padding:9px 20px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;"
                    onmouseover="this.style.background='var(--gold-light)'"
                    onmouseout="this.style.background='var(--gold)'">
                    💳 Pay Now ₹<%= booking.totalAmount %>
                  </button>
                </div>
              <% } %>

              <% if(booking.payment && booking.payment.status === 'Paid') { %>
                <div style="margin-top:8px;font-size:12px;color:#166534;">✅ Payment Done</div>
              <% } %>

              <!-- Review Button — sirf CheckedOut ke baad -->
              <% if(booking.status === 'CheckedOut') { %>
                <div style="margin-top:10px;">
                  <button onclick="openReview('<%= booking._id %>','<%= booking.room._id %>')"
                    style="background:var(--gold);color:white;border:none;padding:8px 16px;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer;">
                    ⭐ Write Review
                  </button>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>


<!-- Review Modal -->
<div id="reviewModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:999;align-items:center;justify-content:center;">
  <div style="background:var(--white);border-radius:16px;padding:32px;width:90%;max-width:480px;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <h3 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;color:var(--text);">Write a Review</h3>
      <button onclick="closeReview()" style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-light);">✕</button>
    </div>
    <div id="reviewResult" style="display:none;margin-bottom:16px;"></div>

    <!-- Star Rating -->
    <div style="margin-bottom:16px;">
      <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:10px;font-weight:500;">Rating *</label>
      <div style="display:flex;gap:8px;" id="starContainer">
        <% [1,2,3,4,5].forEach(s => { %>
          <span onclick="setRating(<%= s %>)" id="star-<%= s %>"
            style="font-size:28px;cursor:pointer;transition:transform 0.15s;">☆</span>
        <% }) %>
      </div>
      <input type="hidden" id="ratingVal" value="0">
    </div>

    <div style="margin-bottom:16px;">
      <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Your Review *</label>
      <textarea id="reviewComment" placeholder="Apna experience share karein..." rows="4"
        style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:11px 14px;border-radius:8px;font-size:14px;outline:none;resize:none;font-family:'Outfit',sans-serif;"></textarea>
    </div>

    <button onclick="submitReview()"
      style="width:100%;background:var(--terracotta);color:white;border:none;padding:13px;border-radius:9px;font-size:15px;font-weight:600;cursor:pointer;">
      Submit Review →
    </button>
  </div>
</div>
<!-- Razorpay Script -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>

// Review Modal
let currentBookingId = '';
let currentRoomId    = '';

function openReview(bookingId, roomId) {
  currentBookingId = bookingId;
  currentRoomId    = roomId;
  document.getElementById('reviewModal').style.display = 'flex';
  document.getElementById('reviewComment').value = '';
  document.getElementById('ratingVal').value = '0';
  document.getElementById('reviewResult').style.display = 'none';
  setRating(0);
}

function closeReview() {
  document.getElementById('reviewModal').style.display = 'none';
}

function setRating(val) {
  document.getElementById('ratingVal').value = val;
  for(let i = 1; i <= 5; i++) {
    const star = document.getElementById('star-' + i);
    if(star) {
      star.textContent = i <= val ? '★' : '☆';
      star.style.color = i <= val ? 'var(--gold)' : 'var(--text-light)';
      star.style.transform = i <= val ? 'scale(1.1)' : 'scale(1)';
    }
  }
}

async function submitReview() {
  const rating  = parseInt(document.getElementById('ratingVal').value);
  const comment = document.getElementById('reviewComment').value.trim();
  const result  = document.getElementById('reviewResult');

  if (!rating || rating < 1) { showReviewResult(false, 'Rating dena zaroori hai'); return; }
  if (comment.length < 10)   { showReviewResult(false, 'Review thoda lamba likho (10+ characters)'); return; }

  try {
    const res  = await fetch('/api/reviews', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ bookingId: currentBookingId, rating, comment }),
    });
    const data = await res.json();
    if (data.success) {
      showReviewResult(true, 'Review submit ho gaya! Shukriya 🙏');
      setTimeout(() => { closeReview(); window.location.reload(); }, 2000);
    } else {
      showReviewResult(false, data.message);
    }
  } catch(e) {
    showReviewResult(false, 'Error aa gaya');
  }
}

function showReviewResult(ok, msg) {
  const el = document.getElementById('reviewResult');
  el.style.display = 'block';
  el.style.background = ok ? '#f0fdf4' : '#fef2f2';
  el.style.border = ok ? '1px solid #86efac' : '1px solid #fca5a5';
  el.style.color  = ok ? '#166534' : '#991b1b';
  el.style.padding = '12px 16px';
  el.style.borderRadius = '8px';
  el.style.fontSize = '13px';
  el.textContent = (ok ? '✅ ' : '❌ ') + msg;
}

async function payNow(bookingId, amount) {
  try {
    // Step 1: Create Razorpay order
    const res  = await fetch('/api/payment/booking/create-order', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ bookingId }),
    });
    const data = await res.json();

    if (!data.success) {
      alert('Payment start nahi ho saka: ' + data.message);
      return;
    }

    // Step 2: Open Razorpay popup
    const options = {
      key:         data.keyId,
      amount:      data.order.amount,
      currency:    data.order.currency,
      name:        'AGR Hotel',
      description: `Room Booking — ₹${amount}`,
      order_id:    data.order.id,
      handler: async function(response) {
        // Step 3: Verify payment
        const verifyRes = await fetch('/api/payment/booking/verify', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({
            bookingId,
            razorpay_order_id:   response.razorpay_order_id,
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_signature:  response.razorpay_signature,
          }),
        });
        const verifyData = await verifyRes.json();

        if (verifyData.success) {
          alert('✅ Payment successful! Booking confirmed!');
          window.location.reload();
        } else {
          alert('❌ Payment verify nahi hua. Please contact us.');
        }
      },
      prefill: {
        name:  '<%= user.name %>',
        email: '<%= user.email %>',
      },
      theme: { color: '#C0392B' },
    };

    const rzp = new Razorpay(options);
    rzp.open();

  } catch(err) {
    alert('Kuch gadbad ho gayi. Please dobara try karo.');
  }
}
</script>

<%- include('partials/footer') %>
