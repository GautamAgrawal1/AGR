<%- include('partials/header') %>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:40px 20px;background:var(--cream);">
  <div style="width:100%;max-width:420px;">
    <div style="text-align:center;margin-bottom:32px;">
      <a href="/" style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:var(--terracotta);letter-spacing:3px;">AGR</a>
      <span style="font-family:'DM Mono',monospace;font-size:9px;color:var(--text-light);letter-spacing:4px;display:block;">HOTEL</span>
    </div>
    <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:36px;box-shadow:var(--shadow-md);">
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:32px;text-align:center;margin-bottom:6px;color:var(--text);">Welcome Back</h1>
      <p style="color:var(--text-light);text-align:center;margin-bottom:28px;font-size:14px;">Login to your account</p>
      <% if (error) { %>
        <div style="background:#fef2f2;border:1px solid #fca5a5;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:20px;font-size:13px;"><%= error %></div>
      <% } %>
      <form action="/login" method="POST">
        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:7px;font-weight:500;">Email</label>
          <input type="email" name="email" required placeholder="aapka@email.com" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:12px 16px;border-radius:9px;font-size:14px;outline:none;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='var(--border)'">
        </div>
        <div style="margin-bottom:24px;">
          <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:7px;font-weight:500;">Password</label>
          <input type="password" name="password" required placeholder="••••••••" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:12px 16px;border-radius:9px;font-size:14px;outline:none;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='var(--border)'">
        </div>
        <button type="submit" style="width:100%;background:var(--terracotta);color:white;border:none;padding:13px;border-radius:9px;font-size:15px;font-weight:500;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.background='var(--terra-light)'" onmouseout="this.style.background='var(--terracotta)'">Login →</button>
      </form>
      <p style="text-align:center;margin-top:20px;font-size:13px;color:var(--text-light);">Account nahi hai? <a href="/signup" style="color:var(--terracotta);font-weight:500;">Signup karo</a></p>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
