<%- include('partials/header') %>

<div style="padding:100px 24px 80px;max-width:1200px;margin:0 auto;">
  <p style="font-family:'DM Mono',monospace;font-size:11px;letter-spacing:4px;color:var(--terracotta);text-transform:uppercase;margin-bottom:10px;">AGR Hotel</p>
  <h1 style="font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:600;margin-bottom:8px;color:var(--text);">Restaurant Menu</h1>
  <p style="color:var(--text-light);margin-bottom:48px;font-size:15px;">Pure Veg · 150+ Dishes · South Indian · Chinese · Biryani · Ice Cream</p>

  <!-- Category Quick Nav -->
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:40px;">
    <% Object.keys(menuByCategory).forEach(cat => { %>
      <a href="#<%= cat.replace(/\s+/g,'-').toLowerCase() %>" style="padding:7px 16px;background:var(--white);border:1.5px solid var(--border);border-radius:99px;font-size:12px;color:var(--text-mid);font-weight:500;transition:all 0.2s;text-decoration:none;" onmouseover="this.style.background='var(--terracotta)';this.style.color='white';this.style.borderColor='var(--terracotta)'" onmouseout="this.style.background='var(--white)';this.style.color='var(--text-mid)';this.style.borderColor='var(--border)'"><%= cat %></a>
    <% }) %>
  </div>

  <% if (Object.keys(menuByCategory).length === 0) { %>
    <div style="text-align:center;padding:80px;background:var(--white);border:1px solid var(--border);border-radius:16px;">
      <p style="font-size:48px;margin-bottom:16px;">🍽️</p>
      <h3 style="font-family:'Cormorant Garamond',serif;font-size:28px;color:var(--text);">Menu abhi available nahi</h3>
    </div>
  <% } else { %>
    <% Object.entries(menuByCategory).forEach(([category, items]) => { %>
      <div id="<%= category.replace(/\s+/g,'-').toLowerCase() %>" style="margin-bottom:56px;">

        <!-- Category Header -->
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:600;color:var(--text);"><%= category %></h2>
          <span style="font-size:12px;color:var(--text-light);background:var(--cream);padding:4px 12px;border-radius:99px;border:1px solid var(--border);"><%= items.length %> items</span>
          <div style="flex:1;height:1px;background:var(--border);"></div>
        </div>

        <!-- Items Grid -->
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;">
          <% items.forEach(item => { %>
            <div style="background:var(--white);border:1px solid var(--border);border-radius:12px;padding:16px 18px;display:flex;justify-content:space-between;align-items:flex-start;gap:12px;transition:all 0.2s;box-shadow:var(--shadow-sm);" onmouseover="this.style.borderColor='var(--gold-border)';this.style.boxShadow='var(--shadow-md)'" onmouseout="this.style.borderColor='var(--border)';this.style.boxShadow='var(--shadow-sm)'">
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:7px;margin-bottom:5px;">
                  <span style="font-size:11px;flex-shrink:0;"><%= item.isVeg ? '🟢' : '🔴' %></span>
                  <h3 style="font-size:14px;font-weight:600;color:var(--text);line-height:1.3;"><%= item.name %></h3>
                </div>
                <% if(item.description){ %>
                  <p style="color:var(--text-light);font-size:12px;margin-bottom:8px;line-height:1.5;"><%= item.description.substring(0,60) %></p>
                <% } %>
                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                  <span style="font-size:10px;color:var(--text-light);background:var(--cream);padding:2px 8px;border-radius:4px;border:1px solid var(--border);"><%= item.spiceLevel %></span>
                  <span style="font-size:10px;color:var(--text-light);background:var(--cream);padding:2px 8px;border-radius:4px;border:1px solid var(--border);">⏱ <%= item.preparationTime %>min</span>
                </div>
              </div>
              <div style="text-align:right;flex-shrink:0;">
                <p style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:600;color:var(--terracotta);">₹<%= item.price %></p>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include('partials/footer') %>
