<%- include('partials/header') %>

<div style="padding:100px 24px 80px;max-width:1200px;margin:0 auto;">
  <p style="font-family:'DM Mono',monospace;font-size:11px;letter-spacing:4px;color:var(--terracotta);text-transform:uppercase;margin-bottom:10px;">Our Rooms</p>
  <h1 style="font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:600;margin-bottom:40px;color:var(--text);">Choose Your Stay</h1>

  <!-- Search Filter -->
  <form action="/rooms" method="GET" style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:48px;background:var(--white);padding:20px 24px;border-radius:14px;border:1px solid var(--border);box-shadow:var(--shadow-sm);">
    <div>
      <label style="display:block;font-size:11px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;font-weight:500;">Check In</label>
      <input type="date" name="checkIn" value="<%= checkIn %>" style="background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
    </div>
    <div>
      <label style="display:block;font-size:11px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;font-weight:500;">Check Out</label>
      <input type="date" name="checkOut" value="<%= checkOut %>" style="background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
    </div>
    <div>
      <label style="display:block;font-size:11px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;font-weight:500;">Room Type</label>
      <select name="type" style="background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
        <option value="">All Types</option>
        <option value="Suite" <%= type==='Suite'?'selected':'' %>>👑 Maharaja Suite</option>
        <option value="Deluxe AC" <%= type==='Deluxe AC'?'selected':'' %>>❄️ Deluxe AC</option>
        <option value="Non-AC" <%= type==='Non-AC'?'selected':'' %>>🏠 Non-AC</option>
        <option value="Dormitory" <%= type==='Dormitory'?'selected':'' %>>🛏️ Dormitory</option>
      </select>
    </div>
    <div style="display:flex;align-items:flex-end;">
      <button type="submit" style="background:var(--terracotta);color:white;border:none;padding:10px 24px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.background='var(--terra-light)'" onmouseout="this.style.background='var(--terracotta)'">Search Rooms</button>
    </div>
  </form>

  <p style="color:var(--text-light);margin-bottom:24px;font-size:14px;"><strong style="color:var(--text);"><%= rooms.length %></strong> rooms available</p>

  <!-- Rooms Grid -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;">
    <% rooms.forEach(room => { %>
    <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:var(--shadow-sm);transition:all 0.3s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 40px rgba(93,58,26,0.15)'" onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='var(--shadow-sm)'">

      <!-- Room Image -->
      <div style="height:200px;overflow:hidden;position:relative;">
        <% if (room.coverImage) { %>
          <img src="<%= room.coverImage %>" alt="<%= room.name %>" style="width:100%;height:100%;object-fit:cover;">
        <% } else { %>
          <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--cream2),var(--cream3));display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;">
            <span style="font-size:48px;"><%= room.type==='Suite'?'👑':room.type==='Deluxe AC'?'❄️':room.type==='Dormitory'?'🛏️':'🏠' %></span>
          </div>
        <% } %>
        <div style="position:absolute;top:12px;left:12px;background:rgba(255,255,255,0.92);backdrop-filter:blur(8px);color:var(--terracotta);font-size:10px;letter-spacing:2px;text-transform:uppercase;padding:4px 10px;border-radius:99px;border:1px solid var(--border);font-weight:600;"><%= room.type %></div>
        <% if(room.amenities.has24x7AC){%><div style="position:absolute;top:12px;right:12px;background:var(--terracotta);color:white;font-size:10px;font-weight:600;padding:4px 10px;border-radius:99px;">24×7 AC</div><%}%>
      </div>

      <!-- Room Body -->
      <div style="padding:20px;">
        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:6px;">
          <h3 style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:600;color:var(--text);"><%= room.name %></h3>
          <% if(room.averageRating>0){%><span style="font-size:12px;color:var(--gold);font-weight:600;">⭐ <%= room.averageRating %></span><%}%>
        </div>
        <p style="color:var(--text-light);font-size:13px;margin-bottom:14px;">Room <%= room.roomNumber %> · Floor <%= room.floor %> · Up to <%= room.capacity %> guests</p>

        <!-- Amenities -->
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px;">
          <%if(room.amenities.hasWifi){%><span style="font-size:11px;color:var(--text-mid);background:var(--cream);padding:3px 8px;border-radius:4px;border:1px solid var(--border);">📶 WiFi</span><%}%>
          <%if(room.amenities.hasAC){%><span style="font-size:11px;color:var(--text-mid);background:var(--cream);padding:3px 8px;border-radius:4px;border:1px solid var(--border);">❄️ AC</span><%}%>
          <%if(room.amenities.hasPowerBackup){%><span style="font-size:11px;color:var(--text-mid);background:var(--cream);padding:3px 8px;border-radius:4px;border:1px solid var(--border);">⚡ Power</span><%}%>
          <%if(room.amenities.hasRoomService){%><span style="font-size:11px;color:var(--text-mid);background:var(--cream);padding:3px 8px;border-radius:4px;border:1px solid var(--border);">🛎️ Service</span><%}%>
        </div>

        <!-- Price + Book -->
        <div style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border);padding-top:16px;">
          <div style="display:flex;align-items:baseline;gap:6px;">
            <span style="font-size:13px;color:var(--text-light);text-decoration:line-through;">₹<%= room.pricing.originalPrice %></span>
            <span style="font-size:24px;font-family:'Cormorant Garamond',serif;color:var(--terracotta);font-weight:600;">₹<%= room.pricing.offerPrice %></span>
            <span style="font-size:11px;color:var(--text-light);">/night</span>
          </div>
          <a href="/rooms/<%= room._id %>" style="background:var(--terracotta);color:white;padding:9px 20px;border-radius:8px;font-size:13px;font-weight:500;transition:all 0.2s;" onmouseover="this.style.background='var(--terra-light)'" onmouseout="this.style.background='var(--terracotta)'">Book Now</a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- Empty State -->
  <% if (rooms.length === 0) { %>
    <div style="text-align:center;padding:80px 20px;background:var(--white);border-radius:16px;border:1px solid var(--border);">
      <p style="font-size:48px;margin-bottom:16px;">😔</p>
      <h3 style="font-family:'Cormorant Garamond',serif;font-size:28px;margin-bottom:8px;color:var(--text);">Koi room available nahi</h3>
      <p style="color:var(--text-light);margin-bottom:24px;">In dates ke liye rooms nahi mile. Doosri dates try karo.</p>
      <a href="/rooms" style="background:var(--terracotta);color:white;padding:12px 28px;border-radius:8px;font-size:14px;">All Rooms Dekho</a>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
