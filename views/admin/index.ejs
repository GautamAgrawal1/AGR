// Load Menu Items
let allMenuItems = [];
async function loadMenuItems() {
  try {
    const res  = await fetch('/api/restaurant/menu?all=true');
    const data = await res.json();
    allMenuItems = data.menu || [];
    renderMenu(allMenuItems);
  } catch(e) { document.getElementById('menu-items-list').innerHTML = '<p style="color:red;">Error</p>'; }
}

function filterMenu() {
  const q = document.getElementById('menuSearch').value.toLowerCase();
  renderMenu(allMenuItems.filter(i => i.name.toLowerCase().includes(q) || i.category.toLowerCase().includes(q)));
}

function renderMenu(items) {
  const el = document.getElementById('menu-items-list');
  if (!items.length) { el.innerHTML = '<p style="color:var(--text-light);">Koi item nahi mila</p>'; return; }
  // Group by category
  const byCategory = items.reduce((acc, item) => {
    if (!acc[item.category]) acc[item.category] = [];
    acc[item.category].push(item);
    return acc;
  }, {});
  el.innerHTML = Object.entries(byCategory).map(([cat, catItems]) => `
    <div style="margin-bottom:24px;">
      <p style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--terracotta);margin-bottom:10px;font-weight:600;">${cat} (${catItems.length})</p>
      ${catItems.map(item => `
        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border:1px solid var(--border);border-radius:8px;margin-bottom:6px;background:var(--cream);">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:11px;">${item.isVeg ? '🟢' : '🔴'}</span>
            <span style="font-size:13px;font-weight:500;color:var(--text);">${item.name}</span>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span style="font-size:14px;font-weight:600;color:var(--terracotta);">₹${item.price}</span>
            <button onclick="deleteMenuItem('${item._id}','${item.name}')" style="background:#fef2f2;border:1px solid #fca5a5;color:#991b1b;padding:4px 10px;border-radius:6px;font-size:11px;cursor:pointer;">Delete</button>
          </div>
        </div>
      `).join('')}
    </div>
  `).join('');
}

async function deleteMenuItem(id, name) {
  if (!confirm(`"${name}" delete karna chahte ho?`)) return;
  try {
    const res  = await fetch('/api/restaurant/menu/' + id, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) { loadMenuItems(); }
    else alert('Error: ' + data.message);
  } catch(e) { alert('Delete failed'); }
}

