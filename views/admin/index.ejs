<%- include('../partials/header') %>

<div style="padding:100px 24px 80px;max-width:1200px;margin:0 auto;background:var(--cream);min-height:100vh;">

  <!-- Header -->
  <div style="margin-bottom:40px;">
    <p style="font-family:'DM Mono',monospace;font-size:11px;letter-spacing:4px;color:var(--terracotta);text-transform:uppercase;margin-bottom:8px;">Admin Panel</p>
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:600;color:var(--text);">Dashboard</h1>
    <p style="color:var(--text-light);font-size:14px;">Welcome, <%= user.name %></p>
  </div>

  <!-- STATS CARDS -->
  <div id="statsGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;margin-bottom:48px;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow-sm);">
      <p style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Total Guests</p>
      <p id="stat-guests" style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:600;color:var(--terracotta);">—</p>
    </div>
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow-sm);">
      <p style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Total Bookings</p>
      <p id="stat-bookings" style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:600;color:var(--terracotta);">—</p>
    </div>
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow-sm);">
      <p style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Active Guests</p>
      <p id="stat-active" style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:600;color:var(--terracotta);">—</p>
    </div>
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow-sm);">
      <p style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Total Revenue</p>
      <p id="stat-revenue" style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:600;color:var(--terracotta);">—</p>
    </div>
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow-sm);">
      <p style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Pending Orders</p>
      <p id="stat-orders" style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:600;color:var(--terracotta);">—</p>
    </div>
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:var(--shadow-sm);">
      <p style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Today Check-ins</p>
      <p id="stat-checkins" style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:600;color:var(--terracotta);">—</p>
    </div>
  </div>

  <!-- TAB NAVIGATION -->
  <div style="display:flex;gap:4px;margin-bottom:28px;background:var(--white);padding:6px;border-radius:12px;border:1px solid var(--border);width:fit-content;flex-wrap:wrap;">
    <% ['Bookings','Orders','Revenue','Users','Menu Items','Add Menu Item','Hotel Photos','Room Photos','Owner Photos','Role Change'].forEach((tab,i) => { %>
      <button onclick="showTab('<%= tab.replace(/\s+/g,'-').toLowerCase() %>')" id="tab-<%= tab.replace(/\s+/g,'-').toLowerCase() %>"
        style="padding:8px 16px;border:none;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;background:<%= i===0?'var(--terracotta)':'transparent' %>;color:<%= i===0?'white':'var(--text-mid)' %>;">
        <%= tab %>
      </button>
    <% }) %>
  </div>

  <!-- ============ TAB: BOOKINGS ============ -->
  <div id="panel-bookings">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:24px;box-shadow:var(--shadow-sm);">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:20px;color:var(--text);">All Bookings</h2>
      <div id="bookings-list"><p style="color:var(--text-light);">Loading...</p></div>
    </div>
  </div>

  <!-- ============ TAB: ORDERS ============ -->
  <div id="panel-orders" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:24px;box-shadow:var(--shadow-sm);">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:20px;color:var(--text);">Pending Orders</h2>
      <div id="orders-list"><p style="color:var(--text-light);">Loading...</p></div>
    </div>
  </div>

  <!-- ============ TAB: REVENUE ============ -->
  <div id="panel-revenue" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:24px;box-shadow:var(--shadow-sm);">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:6px;color:var(--text);">Daily Revenue — Last 30 Days</h2>
      <p style="color:var(--text-light);font-size:13px;margin-bottom:20px;">Har din ka revenue aur bookings</p>
      <div id="revenue-list"><p style="color:var(--text-light);">Loading...</p></div>
    </div>
  </div>

  <!-- ============ TAB: MENU ITEMS ============ -->
  <div id="panel-menu-items" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:24px;box-shadow:var(--shadow-sm);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;color:var(--text);">Menu Items</h2>
        <input type="text" id="menuSearch" placeholder="Search..." oninput="filterMenu()" style="background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:8px 14px;border-radius:8px;font-size:13px;outline:none;width:200px;">
      </div>
      <div id="menu-items-list"><p style="color:var(--text-light);">Loading...</p></div>
    </div>
  </div>

  <!-- ============ TAB: USERS ============ -->
  <div id="panel-users" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:24px;box-shadow:var(--shadow-sm);">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:20px;color:var(--text);">All Users</h2>
      <div id="users-list"><p style="color:var(--text-light);">Loading...</p></div>
    </div>
  </div>

  <!-- ============ TAB: ADD MENU ITEM ============ -->
  <div id="panel-add-menu-item" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:32px;box-shadow:var(--shadow-sm);max-width:600px;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:6px;color:var(--text);">Add Menu Item</h2>
      <p style="color:var(--text-light);font-size:13px;margin-bottom:24px;">Restaurant mein naya dish add karo</p>
      <div id="menuResult" style="display:none;margin-bottom:16px;"></div>
      <form id="menuForm" style="display:flex;flex-direction:column;gap:14px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Item Name *</label>
            <input type="text" name="name" required placeholder="e.g. Paneer Tikka" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
          </div>
          <div>
            <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Price (₹) *</label>
            <input type="number" name="price" required placeholder="200" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Category *</label>
            <select name="category" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
              <option value="Starter">Starter</option>
              <option value="Main Course">Main Course</option>
              <option value="Breakfast">Breakfast</option>
              <option value="Dessert">Dessert</option>
              <option value="Beverage">Beverage</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Spice Level</label>
            <select name="spiceLevel" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
              <option value="Mild">Mild</option>
              <option value="Medium" selected>Medium</option>
              <option value="Spicy">Spicy</option>
              <option value="Extra Spicy">Extra Spicy</option>
            </select>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Veg/Non-Veg</label>
            <select name="isVeg" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
              <option value="true">🟢 Veg</option>
              <option value="false">🔴 Non-Veg</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Prep Time (min)</label>
            <input type="number" name="preparationTime" value="15" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
          </div>
        </div>
        <div>
          <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Description</label>
          <input type="text" name="description" placeholder="Short description (optional)" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
        </div>
        <button type="button" onclick="addMenuItem()" style="background:var(--terracotta);color:white;border:none;padding:12px 24px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;width:fit-content;">Add to Menu →</button>
      </form>
    </div>
  </div>

  <!-- ============ TAB: HOTEL PHOTOS ============ -->
  <div id="panel-hotel-photos" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:32px;box-shadow:var(--shadow-sm);max-width:600px;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:6px;color:var(--text);">Hotel Photos</h2>
      <p style="color:var(--text-light);font-size:13px;margin-bottom:24px;">Home page pe hotel ki photos upload karo — automatically slideshow mein aayengi</p>
      <div id="hotelPhotoResult" style="display:none;margin-bottom:16px;"></div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Hotel Photos (Multiple select kar sakte ho)</label>
          <input type="file" id="hotelPhotoInput" accept="image/*" multiple style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;">
        </div>
        <div id="hotelPhotoPreviewContainer" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
        <button onclick="uploadHotelPhotos()" style="background:var(--terracotta);color:white;border:none;padding:12px 24px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;width:fit-content;">Upload Photos →</button>
      </div>
      <!-- Existing Photos -->
      <div style="margin-top:28px;">
        <h3 style="font-family:'Cormorant Garamond',serif;font-size:18px;margin-bottom:14px;color:var(--text);">Uploaded Photos</h3>
        <div id="existingHotelPhotos" style="display:flex;gap:8px;flex-wrap:wrap;"><p style="color:var(--text-light);font-size:13px;">Loading...</p></div>
      </div>
    </div>
  </div>

  <!-- ============ TAB: ROOM PHOTOS ============ -->
  <div id="panel-room-photos" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:32px;box-shadow:var(--shadow-sm);max-width:600px;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:6px;color:var(--text);">Room Photos Upload</h2>
      <p style="color:var(--text-light);font-size:13px;margin-bottom:24px;">Ek ya multiple photos upload karo — pehli photo cover banega, baaki slideshow mein</p>
      <div id="roomPhotoResult" style="display:none;margin-bottom:16px;"></div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Room Number</label>
          <input type="text" id="roomNumInput" placeholder="e.g. 221, 215, DORM-1" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
        </div>
        <div>
          <label style="display:block;font-size:11px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;font-weight:500;">Photos (Multiple select kar sakte ho)</label>
          <input type="file" id="roomPhotoInput" accept="image/*" multiple style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;">
        </div>
        <div id="roomPhotoPreviewContainer" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
        <button onclick="uploadRoomPhotos()" style="background:var(--terracotta);color:white;border:none;padding:12px 24px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;width:fit-content;">Upload Photos →</button>
      </div>

      <!-- Existing Room Photos -->
      <div style="margin-top:28px;">
        <h3 style="font-family:'Cormorant Garamond',serif;font-size:18px;margin-bottom:6px;color:var(--text);">Uploaded Room Photos</h3>
        <p style="color:var(--text-light);font-size:12px;margin-bottom:14px;">Room number dalo aur Load karo — phir kisi bhi photo ko delete kar sakte ho</p>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:16px;flex-wrap:wrap;">
          <input type="text" id="loadRoomNumInput" placeholder="Room number dalo (e.g. 221)" style="flex:1;min-width:180px;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
          <button onclick="loadRoomPhotos()" style="background:var(--gold);color:white;border:none;padding:10px 20px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;white-space:nowrap;">Load Photos</button>
        </div>
        <div id="existingRoomPhotosMsg" style="display:none;margin-bottom:12px;"></div>
        <div id="existingRoomPhotosList" style="display:flex;gap:10px;flex-wrap:wrap;"></div>
      </div>
    </div>
  </div>

  <!-- ============ TAB: OWNER PHOTOS ============ -->
  <div id="panel-owner-photos" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:32px;box-shadow:var(--shadow-sm);max-width:500px;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:6px;color:var(--text);">Owner Photos</h2>
      <p style="color:var(--text-light);font-size:13px;margin-bottom:24px;">Teeno owners ki photo aur naam update karo</p>
      <div id="ownerResult" style="display:none;margin-bottom:16px;"></div>
      <% [1,2,3].forEach(n => { %>
        <div style="margin-bottom:24px;padding:20px;background:var(--cream);border-radius:10px;border:1px solid var(--border);">
          <p style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:12px;">Owner <%= n %></p>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <input type="text" id="ownerName<%= n %>" placeholder="Owner <%= n %> ka naam" style="width:100%;background:var(--white);border:1.5px solid var(--border);color:var(--text);padding:9px 14px;border-radius:8px;font-size:13px;outline:none;">
            <input type="text" id="ownerRole<%= n %>" placeholder="Role (e.g. Founder & Director)" style="width:100%;background:var(--white);border:1.5px solid var(--border);color:var(--text);padding:9px 14px;border-radius:8px;font-size:13px;outline:none;">
            <input type="file" id="ownerPhoto<%= n %>" accept="image/*" style="width:100%;background:var(--white);border:1.5px solid var(--border);color:var(--text);padding:9px 14px;border-radius:8px;font-size:13px;">
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button onclick="uploadOwnerPhoto(<%= n %>)" style="background:var(--gold);color:white;border:none;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;">Save Owner <%= n %></button>
              <button onclick="deleteOwnerPhoto(<%= n %>)" style="background:#fef2f2;border:1px solid #fca5a5;color:#991b1b;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;">Delete Photo</button>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- ============ TAB: ROLE CHANGE ============ -->
  <div id="panel-role-change" style="display:none;">
    <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:32px;box-shadow:var(--shadow-sm);max-width:500px;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:6px;color:var(--text);">User Role Change</h2>
      <p style="color:var(--text-light);font-size:13px;margin-bottom:24px;">Kisi bhi user ko STAFF ya ADMIN banao</p>
      <div id="roleResult" style="display:none;margin-bottom:16px;"></div>
      <div style="display:flex;flex-direction:column;gap:12px;max-width:400px;">
        <input type="text" id="userEmailInput" placeholder="User ka email" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
        <select id="roleSelect" style="width:100%;background:var(--cream);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-size:14px;outline:none;">
          <option value="GUEST">GUEST</option>
          <option value="STAFF">STAFF</option>
          <option value="ADMIN">ADMIN</option>
        </select>
        <button onclick="changeRole()" style="background:var(--terracotta);color:white;border:none;padding:11px 24px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;width:fit-content;">Update Role →</button>
      </div>
    </div>
  </div>

</div>

<script>
// ================================================
// TAB SWITCHING
// ================================================
function showTab(name) {
  const panels = document.querySelectorAll('[id^="panel-"]');
  panels.forEach(p => p.style.display = 'none');
  document.getElementById('panel-' + name).style.display = 'block';

  const tabs = document.querySelectorAll('[id^="tab-"]');
  tabs.forEach(t => { t.style.background = 'transparent'; t.style.color = 'var(--text-mid)'; });
  const activeTab = document.getElementById('tab-' + name);
  if (activeTab) { activeTab.style.background = 'var(--terracotta)'; activeTab.style.color = 'white'; }

  // Load data on tab open
  if (name === 'bookings')      loadBookings();
  if (name === 'orders')        loadOrders();
  if (name === 'revenue')       loadRevenue();
  if (name === 'users')         loadUsers();
  if (name === 'menu-items')    loadMenuItems();
  if (name === 'hotel-photos')  loadHotelPhotos();
}

// ================================================
// LOAD STATS
// ================================================
async function loadStats() {
  try {
    const res  = await fetch('/api/admin/dashboard');
    const data = await res.json();
    if (!data.success) return;
    const d = data.dashboard;
    document.getElementById('stat-guests').textContent   = d.users.totalGuests;
    document.getElementById('stat-bookings').textContent = d.bookings.total;
    document.getElementById('stat-active').textContent   = d.bookings.activeGuests;
    document.getElementById('stat-revenue').textContent  = '₹' + (d.revenue.allTime || 0).toLocaleString('en-IN');
    document.getElementById('stat-orders').textContent   = d.orders.pending;
    document.getElementById('stat-checkins').textContent = d.bookings.todayCheckIns;
  } catch(e) { console.error('Stats error:', e); }
}

// ================================================
// LOAD BOOKINGS
// ================================================
async function loadBookings() {
  try {
    const res  = await fetch('/api/admin/bookings');
    const data = await res.json();
    const el   = document.getElementById('bookings-list');
    if (!data.bookings || data.bookings.length === 0) {
      el.innerHTML = '<p style="color:var(--text-light);">Koi booking nahi</p>'; return;
    }
    el.innerHTML = data.bookings.map(b => `
      <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:8px;">
        <div>
          <p style="font-weight:600;font-size:14px;color:var(--text);">${b.guest?.name || 'Guest'} — ${b.room?.name || 'Room'} (${b.room?.roomNumber || ''})</p>
