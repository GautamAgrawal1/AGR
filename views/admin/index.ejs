async function uploadHotelPhotos() {
  const files  = document.getElementById('hotelPhotoInput').files;
  const result = document.getElementById('hotelPhotoResult');
  if (!files.length) { showRes(result, false, 'Koi photo select nahi ki'); return; }
  let uploaded = 0;
  for (const file of files) {
    const fd = new FormData();
    fd.append('photo', file);
    try {
      const res  = await fetch('/admin/upload-hotel', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.success) uploaded++;
    } catch(e) {}
  }
  showRes(result, uploaded > 0, `${uploaded} photo(s) upload ho gayi!`);
  loadHotelPhotos();
}

