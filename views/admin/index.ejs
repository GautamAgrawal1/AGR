async function addMenuItem() {
  const form   = document.getElementById('menuForm');
  const result = document.getElementById('menuResult');
  const body   = {
    name:            form.name.value,
    price:           Number(form.price.value),
    category:        form.category.value,
    spiceLevel:      form.spiceLevel.value,
    isVeg:           form.isVeg.value === 'true',
    preparationTime: Number(form.preparationTime.value),
    description:     form.description.value,
  };
  try {
    const res  = await fetch('/api/restaurant/menu', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify(body)
    });
    const data = await res.json();
    result.style.display  = 'block';
    result.className      = data.success ? 'alert-success' : 'alert-error';
    result.textContent    = data.success ? '✅ ' + data.item.name + ' menu mein add ho gaya!' : '❌ ' + data.message;
    if (data.success) form.reset();
  } catch(e) { result.style.display='block'; result.className='alert-error'; result.textContent='❌ Error'; }
}

