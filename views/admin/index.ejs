// LOAD ROOM PHOTOS — Room ki existing photos load karo
async function loadRoomPhotos() {
  const roomNum = document.getElementById('loadRoomNumInput').value.trim();
  const msg     = document.getElementById('existingRoomPhotosMsg');
  const list    = document.getElementById('existingRoomPhotosList');
  if (!roomNum) { showRes(msg, false, 'Room number dalo pehle'); return; }

  msg.style.display = 'block';
  msg.innerHTML = '<p style="color:var(--text-light);font-size:13px;">Loading...</p>';
  list.innerHTML = '';

  try {
    const res  = await fetch('/api/rooms?all=true');
    const data = await res.json();
    const rooms = data.rooms || [];
    const room  = rooms.find(r => String(r.roomNumber) === String(roomNum));

    if (!room) { showRes(msg, false, 'Room "' + roomNum + '" nahi mila'); return; }

    const photos = room.images || [];
    if (!photos.length) { showRes(msg, false, 'Is room mein abhi koi photo nahi hai'); return; }

    msg.style.display = 'none';
    list.innerHTML = photos.map((url, i) =>
      '<div class="room-photo-item" id="rphoto_' + i + '">' +
        '<img src="' + url + '" alt="Room photo ' + (i+1) + '">' +
        '<button class="room-photo-delete-btn" onclick="deleteRoomPhoto(\'' + room._id + '\',\'' + url + '\',\'rphoto_' + i + '\')" title="Delete photo">✕</button>' +
        (i === 0 ? '<span class="room-photo-cover-badge">Cover</span>' : '') +
      '</div>'
    ).join('');
  } catch(e) { showRes(msg, false, 'Error: ' + e.message); }
}

async function deleteRoomPhoto(roomId, photoUrl, containerId) {
  if (!confirm('Yeh photo delete karna chahte ho?')) return;
  const msg = document.getElementById('existingRoomPhotosMsg');
  try {
    const res  = await fetch('/admin/delete-room-photo', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ roomId, photoUrl })
    });
    const data = await res.json();
    if (data.success) {
      const el = document.getElementById(containerId);
      if (el) el.remove();
      showRes(msg, true, 'Photo delete ho gayi!');
      loadRoomPhotos();
    } else { showRes(msg, false, data.message || 'Delete failed'); }
  } catch(e) { showRes(msg, false, 'Error: ' + e.message); }
}

